# Project-local build outputs and generated verification artifacts
new/out/
new/out-*/
verification/
new/verification/
new/verification/*-20*/
new/verification/**/*.raw
new/verification/**/*.bmp
new/verification/**/*.pgm
new/verification/**/*.png
new/verification/test-images/authority-baseline/*-analysis/
new/verification/test-images/authority-baseline/*-overlays/

# Keep verification source contracts tracked while generated media stays ignored.
!new/verification/
!new/verification/tests/
!new/verification/tests/*.cpp
!new/verification/tests/*.sh
!new/verification/test-images/
!new/verification/test-images/authority-baseline/
!new/verification/test-images/authority-baseline/manifest.json
!new/verification/test-images/authority-baseline/*.raw

# Extra guards for generated verification executables if parts of
# verification are force-added later.
new/verification/tests/*_test
new/verification/tests/*_validate
new/verification/tests/*_host
new/verification/tests/*_selftest

# Original and vendor libraries (Do not track, only keep custom code)
old/
old_2/
LS2K0300_Library/
true_LS2K0300_Library/
